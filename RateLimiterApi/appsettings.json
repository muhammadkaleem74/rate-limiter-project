{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "WindowSeconds": 60,
    "DefaultLimit": 100,
    "Clients": {
      "standard": 10,
      "premium": 50,
      "enterprise": 200
    },
    "Endpoints": {
      "POST:/api/data": 5,
      "PUT:/api/data": 5,
      "DELETE:/api/data": 3
    }
  }
}
